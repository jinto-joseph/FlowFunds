# Backend environment variables
# Copy this file to .env and fill in the values
# Then load it before starting the server:
#   set -a && source .env && set +a && uvicorn app.main:app --reload

# Comma-separated list of allowed frontend origins (add your deployed URL here)
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173

# VAPID keys for Web Push notifications
# Run: python3 -m py_vapid --gen   (inside backend venv)
# Then: python3 -m py_vapid --applicationServerKey  → paste into VAPID_PUBLIC_KEY
# Private key: path to private_key.pem generated by py_vapid
VAPID_PUBLIC_KEY=BBmAKyosflI5dP_npF3plbQnIV9iI7MW5RluIlIKmSzVUeh5cPQ7seMU4frdLCIcIToAkm1-ddKxF-neUp4hgig

# Point to the pem file path OR paste the PEM content as a single string
VAPID_PRIVATE_KEY=./private_key.pem

VAPID_CLAIMS=mailto:you@example.com
