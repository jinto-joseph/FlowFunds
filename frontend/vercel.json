{
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/.well-known/assetlinks.json", "destination": "/assetlinks.json" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
